# Copy this file to `.env` and fill in values. `.env` is git-ignored and must
# NEVER be committed. This example contains only placeholders.

# --- Benchmarks --------------------------------------------------------------
# Indices to compare against (comma-separated ETFs). Default: S&P 500, Dow, Nasdaq.
BENCHMARK_TICKERS=VOO,DIA,QQQ

# --- Storage -----------------------------------------------------------------
# Optional override for the local database path (default: data/chasing_voo.sqlite3)
# CHASING_VOO_DB=/absolute/path/to/chasing_voo.sqlite3

# --- Portfolio source --------------------------------------------------------
# "manual" (default, safest) or "robinhood" (optional, unofficial API).
PORTFOLIO_PROVIDER=manual

# --- Robinhood (ONLY needed if PORTFOLIO_PROVIDER=robinhood) ------------------
# WARNING: unofficial API. See README security notes. Leave blank for manual use.
# RH_USERNAME=your_email@example.com
# RH_PASSWORD=your_password
# One of the following for MFA (or neither if MFA is off):
# RH_MFA_CODE=123456
# RH_TOTP_SECRET=YOURBASE32TOTPSECRET
